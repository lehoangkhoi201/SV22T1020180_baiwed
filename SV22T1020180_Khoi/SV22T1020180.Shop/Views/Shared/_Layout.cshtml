@{
    var cart = ApplicationContext.GetSessionData<List<CartItem>>("Cart") ?? new List<CartItem>();
    int cartCount = cart.Sum(c => c.Quantity);
    bool isAuthenticated = User.Identity?.IsAuthenticated == true;
    string customerName = User.Identity?.Name ?? "";
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " - " : "")LHK Shop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400..700;1,9..40,400..700&family=Outfit:wght@500..800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- Top bar -->
    <div class="top-bar d-none d-md-block">
        <div class="container d-flex justify-content-between">
            <span><i class="bi bi-telephone me-1"></i> Hotline: 0123.456.789</span>
            <span><i class="bi bi-truck me-1"></i> Miễn phí giao hàng cho đơn từ 500.000đ</span>
        </div>
    </div>

    <!-- Header -->
    <header class="site-header">
        <div class="container d-flex align-items-center gap-3 flex-wrap">
            <a class="logo d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.png" alt="LHK Shop" class="site-logo-img" width="40" height="40" onerror="this.style.display='none'" />
                LHK<span>Shop</span>
            </a>

            <form class="header-search d-flex mx-3" asp-controller="Product" asp-action="Index" method="get">
                <input type="text" name="search" class="form-control" placeholder="Tìm kiếm sản phẩm..." 
                       value="@Context.Request.Query["search"]" />
                <button class="btn" type="submit"><i class="bi bi-search"></i></button>
            </form>

            <div class="d-flex align-items-center gap-4 ms-auto">
                <a class="header-action" asp-controller="Cart" asp-action="Index">
                    <span style="position:relative">
                        <i class="bi bi-cart3"></i>
                        @if (cartCount > 0)
                        {
                            <span class="cart-badge">@cartCount</span>
                        }
                    </span>
                    <span class="d-none d-lg-inline">Giỏ hàng</span>
                </a>

                @if (isAuthenticated)
                {
                    <div class="dropdown">
                        <a class="header-action dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle"></i>
                            <span class="d-none d-lg-inline">@customerName</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-2"></i>Tài khoản</a></li>
                            <li><a class="dropdown-item" asp-controller="Order" asp-action="History"><i class="bi bi-bag-check me-2"></i>Đơn hàng</a></li>
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword"><i class="bi bi-key me-2"></i>Đổi mật khẩu</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                        </ul>
                    </div>
                }
                else
                {
                    <a class="header-action" asp-controller="Account" asp-action="Login">
                        <i class="bi bi-person"></i>
                        <span class="d-none d-lg-inline">Đăng nhập</span>
                    </a>
                }
            </div>
        </div>
    </header>

    <!-- Navbar -->
    <nav class="site-nav">
        <div class="container">
            <ul class="nav">
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house-door me-1"></i>Trang chủ
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Product" ? "active" : "")" asp-controller="Product" asp-action="Index">
                        <i class="bi bi-grid me-1"></i>Sản phẩm
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Home" && currentAction == "Contact" ? "active" : "")" asp-controller="Home" asp-action="Contact">
                        <i class="bi bi-envelope me-1"></i>Liên hệ
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Home" && currentAction == "About" ? "active" : "")" asp-controller="Home" asp-action="About">
                        <i class="bi bi-info-circle me-1"></i>Giới thiệu
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="site-main py-4">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="site-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <h6><span style="color:var(--secondary)">LHK</span> Shop</h6>
                    <p class="small">Chuyên cung cấp các sản phẩm chất lượng với giá cả hợp lý. Cam kết hàng chính hãng, giao hàng nhanh chóng.</p>
                    <div class="d-flex gap-3 footer-social">
                        <a href="#" aria-label="Facebook"><i class="bi bi-facebook fs-5"></i></a>
                        <a href="#" aria-label="Instagram"><i class="bi bi-instagram fs-5"></i></a>
                        <a href="#" aria-label="YouTube"><i class="bi bi-youtube fs-5"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h6>Liên kết</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li class="mb-2"><a asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                        <li class="mb-2"><a asp-controller="Home" asp-action="About">Giới thiệu</a></li>
                        <li class="mb-2"><a asp-controller="Home" asp-action="Contact">Liên hệ</a></li>
                        <li class="mb-2"><a asp-controller="Home" asp-action="Privacy">Chính sách bảo mật</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-4">
                    <h6>Hỗ trợ</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="#">Chính sách đổi trả</a></li>
                        <li class="mb-2"><a href="#">Chính sách bảo hành</a></li>
                        <li class="mb-2"><a href="#">Hướng dẫn mua hàng</a></li>
                        <li class="mb-2"><a href="#">Phương thức thanh toán</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-4">
                    <h6>Liên hệ</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><i class="bi bi-geo-alt me-2"></i>123 Nguyễn Văn Linh, Đà Nẵng</li>
                        <li class="mb-2"><i class="bi bi-telephone me-2"></i>0123.456.789</li>
                        <li class="mb-2"><i class="bi bi-envelope me-2"></i>contact@lhkshop.vn</li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                &copy; @DateTime.Now.Year <strong>LHK Shop</strong>. All rights reserved.
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
