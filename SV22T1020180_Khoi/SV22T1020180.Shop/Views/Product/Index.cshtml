@model PagedResult<Product>
@{
    ViewData["Title"] = "Sản phẩm";
    var input = ViewBag.SearchInput as ProductSearchInput;
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active">Sản phẩm</li>
        </ol>
    </nav>

    <div class="page-hero page-hero--shop reveal mb-4">
        <h1 class="h4 fw-bold mb-1">Cửa hàng sản phẩm</h1>
        <p class="text-muted mb-0 small">Lọc theo danh mục, giá và từ khóa — giao diện đồng bộ với trang chủ.</p>
    </div>

    <div class="row">
        <!-- Filter Sidebar -->
        <div class="col-lg-3 mb-4">
            <div class="filter-card">
                <h6><i class="bi bi-funnel me-2"></i>Bộ lọc</h6>
                <form asp-controller="Product" asp-action="Index" method="get">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Danh mục</label>
                        <select name="categoryId" class="form-select form-select-sm">
                            <option value="0">Tất cả danh mục</option>
                            @foreach (var c in categories)
                            {
                                if (input?.CategoryID == c.CategoryID)
                                {
                                    <option value="@c.CategoryID" selected>@c.CategoryName</option>
                                }
                                else
                                {
                                    <option value="@c.CategoryID">@c.CategoryName</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Tìm kiếm</label>
                        <input type="text" name="search" class="form-control form-control-sm" placeholder="Tên sản phẩm..." value="@input?.SearchValue" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Khoảng giá</label>
                        <div class="d-flex gap-2">
                            <input type="number" name="minPrice" class="form-control form-control-sm" placeholder="Từ"
                                   value="@(input?.MinPrice > 0 ? input.MinPrice.ToString("0") : "")" />
                            <input type="number" name="maxPrice" class="form-control form-control-sm" placeholder="Đến"
                                   value="@(input?.MaxPrice > 0 ? input.MaxPrice.ToString("0") : "")" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm w-100">
                        <i class="bi bi-search me-1"></i>Tìm kiếm
                    </button>
                </form>
            </div>
        </div>

        <!-- Product Grid -->
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted">Tìm thấy <strong>@Model.RowCount</strong> sản phẩm</span>
            </div>

            @if (Model.DataItems.Any())
            {
                <div class="row g-3 reveal-stagger">
                    @foreach (var p in Model.DataItems)
                    {
                        <div class="col-6 col-md-4">
                            <div class="product-card reveal h-100">
                                <a asp-action="Detail" asp-route-id="@p.ProductID">
                                    <div class="card-img-wrap">
                                        <img src="@(string.IsNullOrEmpty(p.Photo) ? "/images/products/noproduct.png" : "/images/products/" + p.Photo)"
                                             alt="@p.ProductName" />
                                    </div>
                                </a>
                                <div class="card-body">
                                    <a class="product-name" asp-action="Detail" asp-route-id="@p.ProductID">@p.ProductName</a>
                                    <div class="product-price">@p.Price.ToString("N0") đ</div>
                                    <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                        <input type="hidden" name="productId" value="@p.ProductID" />
                                        <button type="submit" class="btn btn-add-cart w-100">
                                            <i class="bi bi-cart-plus me-1"></i>Thêm vào giỏ
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.PageCount > 1)
                {
                    <nav class="mt-4">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-page="@(Model.Page - 1)"
                                   asp-route-search="@input?.SearchValue"
                                   asp-route-categoryId="@input?.CategoryID"
                                   asp-route-minPrice="@input?.MinPrice"
                                   asp-route-maxPrice="@input?.MaxPrice">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                            @foreach (var p in Model.GetDisplayPages())
                            {
                                if (p.IsEllipsis)
                                {
                                    <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                                }
                                else
                                {
                                    <li class="page-item @(p.IsCurrent ? "active" : "")">
                                        <a class="page-link" asp-action="Index"
                                           asp-route-page="@p.Page"
                                           asp-route-search="@input?.SearchValue"
                                           asp-route-categoryId="@input?.CategoryID"
                                           asp-route-minPrice="@input?.MinPrice"
                                           asp-route-maxPrice="@input?.MaxPrice">@p.Page</a>
                                    </li>
                                }
                            }
                            <li class="page-item @(Model.Page >= Model.PageCount ? "disabled" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-page="@(Model.Page + 1)"
                                   asp-route-search="@input?.SearchValue"
                                   asp-route-categoryId="@input?.CategoryID"
                                   asp-route-minPrice="@input?.MinPrice"
                                   asp-route-maxPrice="@input?.MaxPrice">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="empty-state text-center">
                    <div class="empty-state-icon"><i class="bi bi-search"></i></div>
                    <p class="text-muted mb-3">Không tìm thấy sản phẩm nào phù hợp. Thử đổi bộ lọc hoặc từ khóa.</p>
                    <a asp-action="Index" class="btn btn-primary btn-sm">Xóa bộ lọc</a>
                </div>
            }
        </div>
    </div>
</div>
