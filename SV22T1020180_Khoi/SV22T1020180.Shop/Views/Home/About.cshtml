@{
    ViewData["Title"] = "Giới thiệu";
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active">Giới thiệu</li>
        </ol>
    </nav>

    <div class="page-hero reveal mb-4">
        <h1 class="h4 fw-bold mb-1">Về LHK Shop</h1>
        <p class="text-muted mb-0 small">Công nghệ chính hãng — giao nhanh — hỗ trợ tận tình.</p>
    </div>

    <div class="static-page-card p-4 p-lg-5 reveal">
        <div class="text-center mb-5">
            <h1 class="fw-bold" style="color:var(--dark);">Về <span style="color:var(--primary);">LHK</span><span style="color:var(--secondary);">Shop</span></h1>
            <p class="text-muted fs-5">Nơi mua sắm đáng tin cậy của bạn</p>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-4 text-center">
                <div class="p-3">
                    <i class="bi bi-shield-check fs-1 text-primary mb-3 d-block"></i>
                    <h5 class="fw-bold">Hàng chính hãng</h5>
                    <p class="text-muted">100% sản phẩm chính hãng, có nguồn gốc rõ ràng, đầy đủ tem nhãn và phiếu bảo hành.</p>
                </div>
            </div>
            <div class="col-md-4 text-center">
                <div class="p-3">
                    <i class="bi bi-truck fs-1 text-primary mb-3 d-block"></i>
                    <h5 class="fw-bold">Giao hàng nhanh</h5>
                    <p class="text-muted">Giao hàng toàn quốc trong 1-3 ngày. Miễn phí vận chuyển cho đơn hàng từ 500.000đ.</p>
                </div>
            </div>
            <div class="col-md-4 text-center">
                <div class="p-3">
                    <i class="bi bi-headset fs-1 text-primary mb-3 d-block"></i>
                    <h5 class="fw-bold">Hỗ trợ 24/7</h5>
                    <p class="text-muted">Đội ngũ tư vấn luôn sẵn sàng hỗ trợ bạn mọi lúc, mọi nơi.</p>
                </div>
            </div>
        </div>

        <div class="row align-items-center">
            <div class="col-lg-8 mx-auto">
                <h4 class="fw-bold mb-3">Câu chuyện của chúng tôi</h4>
                <p>LHK Shop được thành lập với sứ mệnh mang đến cho khách hàng những sản phẩm chất lượng nhất với giá cả hợp lý nhất. Chúng tôi tin rằng mỗi khách hàng đều xứng đáng được trải nghiệm mua sắm tuyệt vời.</p>
                <p>Với đội ngũ nhân viên nhiệt tình, hệ thống kho hàng hiện đại và mạng lưới giao hàng rộng khắp, chúng tôi cam kết mang đến cho bạn sự hài lòng tuyệt đối.</p>
                <p class="mb-0"><strong>LHK Shop - Mua sắm thông minh, sống chất lượng!</strong></p>
            </div>
        </div>
    </div>
</div>
