@{
    ViewData["Title"] = "Liên hệ";
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active">Liên hệ</li>
        </ol>
    </nav>

    <div class="page-hero reveal mb-4">
        <h1 class="h4 fw-bold mb-1">Liên hệ LHK Shop</h1>
        <p class="text-muted mb-0 small">Chúng tôi luôn sẵn sàng hỗ trợ bạn qua điện thoại, email hoặc biểu mẫu bên dưới.</p>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="static-page-card h-100 reveal">
                <h2 class="section-title">Thông tin liên hệ</h2>
                <div class="mb-4">
                    <div class="d-flex align-items-start mb-3">
                        <i class="bi bi-geo-alt-fill text-primary fs-4 me-3 mt-1"></i>
                        <div>
                            <h6 class="mb-1 fw-bold">Địa chỉ</h6>
                            <p class="text-muted mb-0">123 Nguyễn Văn Linh, Q. Hải Châu, TP. Đà Nẵng</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-start mb-3">
                        <i class="bi bi-telephone-fill text-primary fs-4 me-3 mt-1"></i>
                        <div>
                            <h6 class="mb-1 fw-bold">Điện thoại</h6>
                            <p class="text-muted mb-0">0123.456.789</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-start mb-3">
                        <i class="bi bi-envelope-fill text-primary fs-4 me-3 mt-1"></i>
                        <div>
                            <h6 class="mb-1 fw-bold">Email</h6>
                            <p class="text-muted mb-0">contact@lhkshop.vn</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-start">
                        <i class="bi bi-clock-fill text-primary fs-4 me-3 mt-1"></i>
                        <div>
                            <h6 class="mb-1 fw-bold">Giờ làm việc</h6>
                            <p class="text-muted mb-0">Thứ 2 - Thứ 7: 8:00 - 21:00<br />Chủ nhật: 9:00 - 18:00</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="static-page-card h-100 reveal">
                <h2 class="section-title">Gửi tin nhắn</h2>
                <form>
                    <div class="mb-3">
                        <label class="form-label">Họ tên</label>
                        <input type="text" class="form-control" placeholder="Nhập họ tên" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" placeholder="Nhập email" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nội dung</label>
                        <textarea class="form-control" rows="4" placeholder="Nội dung tin nhắn..."></textarea>
                    </div>
                    <button type="button" class="btn btn-primary" onclick="alert('Cảm ơn bạn đã liên hệ! Chúng tôi sẽ phản hồi sớm nhất.')">
                        <i class="bi bi-send me-2"></i>Gửi tin nhắn
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
