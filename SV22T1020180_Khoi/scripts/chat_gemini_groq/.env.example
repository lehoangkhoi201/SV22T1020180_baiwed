# Bước 1: Sao chép file này thành file tên ".env" (cùng thư mục với app.py).
#    PowerShell: Copy-Item .env.example .env
# Bước 2: Mở ".env" và điền key thật (không commit file ".env" lên git).
#
# Lưu ý: Ứng dụng chỉ load file ".env" — KHÔNG tự đọc ".env.example".
XAI_API_KEY=your-xai-key-here
GEMINI_API_KEY=your-gemini-key-here
